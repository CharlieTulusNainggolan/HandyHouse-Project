{
  "name": "handyhouse-tmp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:crm\" \"npm run dev:hr\"",
    "dev:next": "next dev -p 3000",
    "dev:crm": "node services/crm/server.js",
    "dev:hr": "node services/hr/server.js",
    "kill:3000": "npx -y kill-port 3000",
    "kill:3001": "npx -y kill-port 3001",
    "kill:3002": "npx -y kill-port 3002",
    "kill:all": "npx -y kill-port 3000 3001 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "minio": "^8.0.7",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
